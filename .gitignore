# --- Python & Compiled Code ---
__pycache__/
*.py[cod]
*$py.class

# --- OS Noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- Anki & Add-on Junk ---
# Logs that accumulate over time
*.log
# Temporary files generated by some add-ons
tmp/
temp/
_temp/
# Ignore Anki database backups if they accidentally end up here
*.bak

# --- Git Management (The "Repo in Repo" Problem) ---
# If you use 'git clone' to install add-ons, each add-on folder 
# has its own .git directory. Usually, you want to keep those 
# sub-repositories intact so you can 'git pull' updates, 
# so we do NOT ignore .git here. 
# However, if you are getting errors about nested repos, 
# you may need to explicitly ignore those internal .git folders.
# (Uncomment the line below ONLY if you want to flatten all add-ons into one repo)
# **/*.git/